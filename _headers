/*
  # Security headers
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

  # SEO headers
  X-Robots-Tag: index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1
  Link: </sitemap.xml>; rel="sitemap"; type="application/xml"

  # Performance headers
  Cache-Control: public, max-age=31536000, immutable

/*.html
  # HTML files - shorter cache
  Cache-Control: public, max-age=3600

/*.css
  # CSS files - long cache with immutable
  Cache-Control: public, max-age=31536000, immutable

/*.js
  # JavaScript files - long cache with immutable
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  # Image files - long cache
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  # Image files - long cache
  Cache-Control: public, max-age=31536000, immutable

/*.png
  # Image files - long cache
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  # WebP images - long cache
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  # SVG files - long cache
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  # Font files - long cache
  Cache-Control: public, max-age=31536000, immutable

/sitemap.xml
  # Sitemap - shorter cache for SEO updates
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: index, follow

/robots.txt
  # Robots file - shorter cache
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: noindex